{
  "expo": {
    "name": "qfare",
    "slug": "qfare-app",
    "owner": "qfareindia",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f6f9fc"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f6f9fc"
      },
      "package": "com.qfare.app",
      "softwareKeyboardLayoutMode": "pan",
      "privacyPolicyUrl": "https://wbtc-rose.vercel.app/qfare-privacy-policy",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-camera",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "qfare uses your location to auto-detect your nearest bus stop and confirm you are at a bus stop before sending a wait notification."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00c896"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f028ecbb-a05b-4deb-bd02-b3f46efaad1c"
      }
    }
  }
}
