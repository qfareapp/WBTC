PORT=5000
JWT_SECRET=replace-with-a-long-random-secret

# Use a separate database for local development.
# Example:
# mongodb+srv://<user>:<password>@<cluster>.mongodb.net/wbtc_fleet_dev?retryWrites=true&w=majority
MONGO_URI=

# Optional geocoding settings
NOMINATIM_USER_AGENT=WBTCFleetApp/1.0 (fleet@wbtc.gov.in)
GEOCODE_CITY_CONTEXT=Kolkata, West Bengal, India

# SMTP config for passenger OTP emails (Gmail example)
# For Gmail: enable "App Passwords" (2FA required) and use the app password below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=qfare <your-email@gmail.com>

# Firebase Cloud Messaging for driver APK push notifications.
# Provide either the full JSON inline or a path to the downloaded service-account JSON file.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=
